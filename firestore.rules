rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    function isSignedIn() {
      return request.auth != null;
    }

    // NOTE: This function uses get() and can ONLY be used in rules for single-document
    // operations like 'get', 'update', 'delete'. It CANNOT be used to validate 'list' queries.
    function isManager() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && userData != null && 'role' in userData && userData.role.lower() == 'manager';
    }

    // =====================================================================
    // User Profiles
    // =====================================================================
    match /users/{userId} {
      // A user can get their own profile. A manager can get any profile. This is safe.
      allow get: if isManager() || request.auth.uid == userId;
      // Listing users is only allowed for managers (e.g., for the user management page).
      allow list: if isManager();
      allow create: if request.auth.uid == userId;
      // Only a manager can change roles or update other users.
      allow update: if isManager() || request.auth.uid == userId;
      allow delete: if isManager() && request.auth.uid != userId;
    }

    // =====================================================================
    // Business Data Collections (Leads, Opportunities, etc.)
    // =====================================================================
    match /leads/{leadId} {
      // A user can read a lead document if their UID is on it.
      allow read: if request.auth.uid == resource.data.sellerId;
      // A user can create a lead if they set themselves as the seller.
      allow create: if request.resource.data.sellerId == request.auth.uid;
      // A manager can update/delete anything. A seller can only update/delete their own docs.
      allow update, delete: if isManager() || request.auth.uid == resource.data.sellerId;
    }
    
    match /opportunities/{opportunityId} {
      allow read: if request.auth.uid == resource.data.sellerId;
      allow create: if request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isManager() || request.auth.uid == resource.data.sellerId;
    }

    match /quotations/{quotationId} {
      allow read: if request.auth.uid == resource.data.sellerId;
      allow create: if request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isManager() || request.auth.uid == resource.data.sellerId;
    }

    match /activities/{activityId} {
      allow read: if request.auth.uid == resource.data.sellerId;
      allow create: if request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isManager() || request.auth.uid == resource.data.sellerId;
    }
  }
}
