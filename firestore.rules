/**
 * Core Philosophy:
 * This ruleset implements a Role-Based Access Control (RBAC) model for a sales CRM.
 * Access is primarily determined by a user's role ('Admin', 'Manager', 'Seller')
 * which is stored on their user profile. Sellers have ownership-based access to
 * the leads and associated data they manage, while Admins and Managers have
 * privileged access across all data. The default security posture is to deny all
 * access unless explicitly granted by a rule.
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profile documents, including their role.
 *   This path was simplified from the original IR path `/users/{userId}/profile`
 *   to create a more standard, performant, and secure way to fetch a user's role
 *   for authorization decisions.
 * - /leads/{leadId}: A top-level collection for all sales leads.
 * - /opportunities/{opportunityId}: Top-level collection for sales opportunities.
 * - /quotations/{quotationId}: Top-level collection for quotations.
 * - /activities/{activityId}: Top-level collection for sales activities.
 *
 * Key Security Decisions:
 * - Role-Based Access: A user's role is fetched from their profile document at
 *   `/users/{request.auth.uid}` to make authorization decisions throughout the rules.
 * - Disallow User Listing: Listing the entire `/users` collection is explicitly
 *   forbidden to protect user privacy.
 * - Ownership for Sellers: Sellers can only read or write leads/opportunities that
 *   are assigned to them via the `sellerId` field.
 * - Privileged Access: Admins and Managers are granted read and write access to
 *   all leads, opportunities, quotations, and activities.
 *
 * Denormalization for Authorization:
 * To ensure performant and secure access control, a `sellerId` field MUST be
 * denormalized (copied) onto every document in the `/leads`, `/opportunities`,
 * `/quotations`, and `/activities` collections. This avoids slow and costly `get`
 * calls in the rules. The application logic is responsible for ensuring this
 * `sellerId` is present and correct upon document creation.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Authenticated state checks
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Ownership checks
     * @param userId The UID to check against the authenticated user's UID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Role-based access checks. Fetches the user's role from their profile.
     */
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    function isManager() {
      return isSignedIn() && getUserData().role == 'Manager';
    }
    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    /**
     * Data validation functions
     */
    function isCreatingOwnProfile(userId) {
      // On create, the user must be the owner and set their own UID correctly.
      return isOwner(userId) && request.resource.data.firebaseUid == userId;
    }
    function isProfileDataImmutable() {
      // On update, core identifying fields must not be changed.
      return request.resource.data.firebaseUid == resource.data.firebaseUid;
    }
    function isAssignedToSelfOnCreate() {
      // On create, a seller must assign the new document to themselves.
      return request.resource.data.sellerId == request.auth.uid;
    }
    function isSellerIdImmutable() {
      // On update, the sellerId cannot be changed to prevent unauthorized re-assignment.
      return request.resource.data.sellerId == resource.data.sellerId;
    }


    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    /**
     * @description Manages user profiles. A user can create, read, and update their own profile, but cannot see other users' profiles.
     * @path /users/{userId}
     * @allow (create) An authenticated user creating their own profile document where `userId` matches their UID.
     * @deny (get) A user trying to read another user's profile document.
     * @principle Restricts access to a user's own data tree and forbids user enumeration.
     */
    match /users/{userId} {
      // This rule is essential. It allows users to read their own profile,
      // which is required on almost every page for the app to function correctly.
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isCreatingOwnProfile(userId);
      allow update: if isOwner(userId) && resource != null && isProfileDataImmutable();
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Manages sales leads. Sellers can manage leads assigned to them. Admins and Managers can manage any lead.
     * @path /leads/{leadId}
     * @allow (update) The seller assigned to the lead (via `sellerId`) updates the lead status.
     * @deny (update) A seller trying to update a lead assigned to another seller.
     * @principle Enforces document ownership for writes and provides privileged role-based access.
     */
    match /leads/{leadId} {
      allow get: if isAdminOrManager() || (resource.data.sellerId != null && isOwner(resource.data.sellerId));
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isAssignedToSelfOnCreate();
      allow update: if (isAdminOrManager() || (resource != null && isOwner(resource.data.sellerId))) && isSellerIdImmutable();
      allow delete: if isAdminOrManager() || (resource != null && isOwner(resource.data.sellerId));
    }

    /**
     * @description Manages sales opportunities. Access is inherited from the lead's assigned seller.
     * @path /opportunities/{opportunityId}
     * @allow (get) An Admin reading any opportunity document.
     * @deny (get) A Seller trying to read an opportunity not assigned to them.
     * @principle Relies on denormalized ownership data (`sellerId`) to secure related documents.
     * @note CRITICAL: For these rules to be secure, a `sellerId` field MUST be denormalized from the parent Lead onto every Opportunity document.
     */
    match /opportunities/{opportunityId} {
      allow get: if isAdminOrManager() || (resource.data.sellerId != null && isOwner(resource.data.sellerId));
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isAssignedToSelfOnCreate();
      allow update: if (isAdminOrManager() || (resource != null && isOwner(resource.data.sellerId))) && isSellerIdImmutable();
      allow delete: if isAdminOrManager() || (resource != null && isOwner(resource.data.sellerId));
    }

    /**
     * @description Manages quotations for opportunities. Access is inherited from the lead's assigned seller.
     * @path /quotations/{quotationId}
     * @allow (create) A Seller creating a new quotation for one of their opportunities.
     * @deny (delete) A Seller trying to delete a quotation belonging to another seller.
     * @principle Relies on denormalized ownership data (`sellerId`) to secure related documents.
     * @note CRITICAL: For these rules to be secure, a `sellerId` field MUST be denormalized from the parent Lead/Opportunity onto every Quotation document.
     */
    match /quotations/{quotationId} {
      allow get: if isAdminOrManager() || (resource.data.sellerId != null && isOwner(resource.data.sellerId));
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isAssignedToSelfOnCreate();
      allow update: if (isAdminOrManager() || (resource != null && isOwner(resource.data.sellerId))) && isSellerIdImmutable();
      allow delete: if isAdminOrManager() || (resource != null && isOwner(resource.data.sellerId));
    }

    /**
     * @description Manages activities related to leads. Access is inherited from the lead's assigned seller.
     * @path /activities/{activityId}
     * @allow (get) A Manager reading an activity for a lead belonging to one of their team members.
     * @deny (update) A Seller trying to modify an activity for a lead they do not own.
     * @principle Relies on denormalized ownership data (`sellerId`) to secure related documents.
     * @note CRITICAL: For these rules to be secure, a `sellerId` field MUST be denormalized from the parent Lead onto every Activity document.
     */
    match /activities/{activityId} {
      allow get: if isAdminOrManager() || (resource.data.sellerId != null && isOwner(resource.data.sellerId));
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isAssignedToSelfOnCreate();
      allow update: if (isAdminOrManager() || (resource != null && isOwner(resource.data.sellerId))) && isSellerIdImmutable();
      allow delete: if isAdminOrManager() || (resource != null && isOwner(resource.data.sellerId));
    }
  }
}

    