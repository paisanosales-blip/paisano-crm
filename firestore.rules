rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isManager() {
      let userData = getUserData();
      return isSignedIn() && userData != null && 'role' in userData && userData.role.lower() == 'manager';
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isManager() || request.auth.uid == userId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (isManager() || request.auth.uid == userId);
      allow delete: if isManager() && request.auth.uid != userId;
    }

    match /leads/{leadId} {
      allow get: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
    }
    
    match /opportunities/{opportunityId} {
      allow get: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
    }

    match /quotations/{quotationId} {
      allow get: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
    }

    match /activities/{activityId} {
      allow get: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
    }
  }
}
