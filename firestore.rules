rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    function isSignedIn() {
      return request.auth != null;
    }

    // NOTE: This function uses get() and can ONLY be used in rules for single-document
    // operations like 'get', 'update', 'delete'. It CANNOT be used to validate 'list' queries.
    function isManager() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && userData != null && 'role' in userData && userData.role.lower() == 'manager';
    }

    // =====================================================================
    // User Profiles
    // =====================================================================
    match /users/{userId} {
      // A manager can get any profile, a user can get their own. Safe to use isManager() here for a single 'get'.
      allow get: if isManager() || request.auth.uid == userId;
      // Any signed-in user can list all users to populate the manager's dropdown.
      allow list: if isSignedIn();
      // A user can only create their own profile document.
      allow create: if request.auth.uid == userId;
      // A manager can update any profile, a user can update their own.
      allow update: if isManager() || request.auth.uid == userId;
      // Only a manager can delete another user.
      allow delete: if isManager() && request.auth.uid != userId;
    }

    // =====================================================================
    // Business Data Collections (Leads, Opportunities, etc.)
    // =====================================================================
    match /leads/{leadId} {
      // READ: Allow any signed-in user. The app's queries MUST provide
      // the actual filtering for sellers (e.g., `where('sellerId', '==', uid)`).
      // This is the only way to allow managers to perform broad queries without
      // violating the "no get() in list rules" constraint.
      allow read: if isSignedIn();

      // WRITE: Rules are more restrictive and can use isManager() safely because
      // these are single-document operations.
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
    }
    
    match /opportunities/{opportunityId} {
      // READ: Allow any signed-in user.
      allow read: if isSignedIn();
      // WRITE: Secure write rules.
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
    }

    match /quotations/{quotationId} {
      // READ: Allow any signed-in user.
      allow read: if isSignedIn();
      // WRITE: Secure write rules.
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
    }

    match /activities/{activityId} {
      // READ: Allow any signed-in user.
      allow read: if isSignedIn();
      // WRITE: Secure write rules.
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isManager() || resource.data.sellerId == request.auth.uid);
    }
  }
}
