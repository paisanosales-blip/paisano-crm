rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    function isSignedIn() {
      return request.auth != null;
    }

    // NOTE: This function uses get() and can ONLY be used in rules for single-document
    // operations like 'get', 'update', 'delete'. It CANNOT be used to validate 'list' queries.
    function isManager() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && userData != null && 'role' in userData && userData.role.lower() == 'manager';
    }

    // =====================================================================
    // User Profiles
    // =====================================================================
    match /users/{userId} {
      allow get: if isManager() || request.auth.uid == userId;
      allow list: if isSignedIn();
      allow create: if request.auth.uid == userId;
      allow update: if isManager() || request.auth.uid == userId;
      allow delete: if isManager() && request.auth.uid != userId;
    }

    // =====================================================================
    // Business Data Collections (Leads, Opportunities, etc.)
    // =====================================================================
    match /leads/{leadId} {
      // For 'list' operations, we allow any signed-in user to attempt a query.
      // The security is then enforced by the queries in the application code,
      // which MUST include `where('sellerId', '==', request.auth.uid)` for non-managers.
      // This permissive rule is necessary to allow 'manager' users to query across all sellers.
      allow list: if isSignedIn();
      
      // For single-document reads ('get') and writes ('update', 'delete'), we can enforce ownership.
      allow get, delete: if isManager() || resource.data.sellerId == request.auth.uid;
      
      // A user can create a lead if they set themselves as the seller.
      allow create: if request.resource.data.sellerId == request.auth.uid;
      
      // A manager can update anything. A seller can update their own doc, but cannot change the owner.
      allow update: if isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId);
    }
    
    match /opportunities/{opportunityId} {
      allow list: if isSignedIn();
      allow get, delete: if isManager() || resource.data.sellerId == request.auth.uid;
      allow create: if request.resource.data.sellerId == request.auth.uid;
      allow update: if isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId);
    }

    match /quotations/{quotationId} {
      allow list: if isSignedIn();
      allow get, delete: if isManager() || resource.data.sellerId == request.auth.uid;
      allow create: if request.resource.data.sellerId == request.auth.uid;
      allow update: if isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId);
    }

    match /activities/{activityId} {
      allow list: if isSignedIn();
      allow get, delete: if isManager() || resource.data.sellerId == request.auth.uid;
      allow create: if request.resource.data.sellerId == request.auth.uid;
      allow update: if isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId);
    }

    match /products/{productId} {
      allow list: if isSignedIn();
      allow get, delete: if isManager() || resource.data.sellerId == request.auth.uid;
      allow create: if request.resource.data.sellerId == request.auth.uid;
      allow update: if isManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId);
    }
  }
}
