rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================
    // Helper functions
    // ===============================
    function isSignedIn() {
      return request.auth != null;
    }

    // ⚠️ This function uses get() and can ONLY be used in rules for single-document
    // operations like 'get', 'update', 'delete'. It CANNOT be used to validate 'list' queries.
    function isManager() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn()
        && userData != null
        && 'role' in userData
        && userData.role.lower() == 'manager';
    }

    // ===============================
    // Users Collection
    // ===============================
    match /users/{userId} {
      // A manager can get any profile, and users can get their own.
      allow get: if isManager() || request.auth.uid == userId;
      
      // Only a manager can list all users.
      // NOTE: This uses isManager() which has a get() call. This rule might be problematic
      // if the query is complex, but it is the correct security posture.
      allow list: if isManager();
      
      // A user can create their own profile document.
      allow create: if request.auth.uid == userId;

      // A manager can update any profile, and users can update their own.
      allow update: if isManager() || request.auth.uid == userId;

      // A manager can delete any user except themselves.
      allow delete: if isManager() && request.auth.uid != userId;
    }

    // ===============================
    // Business Data Collections
    // (Leads, Opportunities, Quotations, Activities)
    // ===============================
    match /{collection}/{docId} where collection in ['leads', 'opportunities', 'quotations', 'activities'] {
      
      // SECURE GET: A user can GET a document if they are the manager or the assigned seller.
      // This is safe because isManager() is allowed for single-document reads.
      allow get: if isManager() || (resource.data.sellerId == request.auth.uid);

      // PERMISSIVE LIST: Allow any signed-in user to perform LIST queries.
      // This is necessary to prevent permission errors on the Manager's dashboard, which
      // needs to query across all sellers. The client-side code is responsible for
      // filtering data appropriately for Sellers. Security for individual document access
      // is still enforced by the 'get' and 'write' rules.
      allow list: if isSignedIn();

      // SECURE WRITES:
      // A user can only create documents where they are the seller.
      allow create: if request.resource.data.sellerId == request.auth.uid;
      
      // A manager can update/delete any document. A seller can only update/delete their own.
      allow update, delete: if isManager() || resource.data.sellerId == request.auth.uid;
    }
  }
}
