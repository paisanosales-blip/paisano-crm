rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      // It's safer to check for existence before accessing data
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isAdmin() {
      let userData = getUserData();
      return isSignedIn() && userData != null && userData.role == 'Admin';
    }

    function isManager() {
      let userData = getUserData();
      return isSignedIn() && userData != null && userData.role == 'Manager';
    }

    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdminOrManager());
      allow create: if isSignedIn() && isOwner(userId);
      // Allow users to update their own profile, but not change their role.
      allow update: if isSignedIn() && isOwner(userId) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin() && request.auth.uid != userId; // Admins can delete other users, but not themselves.
    }

    match /leads/{leadId} {
      allow get: if isSignedIn() && (isAdminOrManager() || resource.data.sellerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.sellerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isAdminOrManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isAdminOrManager() || resource.data.sellerId == request.auth.uid);
    }
    
    match /opportunities/{opportunityId} {
      allow get: if isSignedIn() && (isAdminOrManager() || resource.data.sellerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.sellerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isAdminOrManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isAdminOrManager() || resource.data.sellerId == request.auth.uid);
    }

    match /quotations/{quotationId} {
      allow get: if isSignedIn() && (isAdminOrManager() || resource.data.sellerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.sellerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isAdminOrManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isAdminOrManager() || resource.data.sellerId == request.auth.uid);
    }

    match /activities/{activityId} {
      allow get: if isSignedIn() && (isAdminOrManager() || resource.data.sellerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.sellerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (isAdminOrManager() || (resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId));
      allow delete: if isSignedIn() && (isAdminOrManager() || resource.data.sellerId == request.auth.uid);
    }
  }
}
