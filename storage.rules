rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isManager() {
      return isSignedIn() && exists(/databases/(default)/documents/users/$(request.auth.uid)) && getUserData().role.lower() == 'manager';
    }

    function isOpportunityOwner(opportunityId) {
      return exists(/databases/(default)/documents/opportunities/$(opportunityId)) &&
             get(/databases/(default)/documents/opportunities/$(opportunityId)).data.sellerId == request.auth.uid;
    }
    
    function isTicketAgent(ticketId) {
      return exists(/databases/(default)/documents/serviceTickets/$(ticketId)) &&
             get(/databases/(default)/documents/serviceTickets/$(ticketId)).data.assignedAgentId == request.auth.uid;
    }

    // ------------------------------------------------------------------------
    // Path Rules
    // ------------------------------------------------------------------------

    match /profile-pictures/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    match /quotations/{opportunityId}/{allPaths=**} {
      allow read, write: if isSignedIn() && (isManager() || isOpportunityOwner(opportunityId));
    }

    match /app/{allPaths=**} {
      allow read: if true;
      allow write: if isManager();
    }

    match /marketing_uploads/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /shared-files/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /service_evidence/{ticketId}/{allPaths=**} {
      allow read: if isSignedIn() && (isManager() || isTicketAgent(ticketId));
      allow write: if isSignedIn() && (isManager() || isTicketAgent(ticketId));
    }
  }
}
